{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/pose_estimation_dashboard.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
